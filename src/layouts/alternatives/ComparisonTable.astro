const { alt } = Astro.props;
const alternativeData = comparisonData[alt as keyof typeof comparisonData];
---

<Section class="p-0!" slotClass="p-0!">
  <ComparisonTableComponent
    openlaneFeatures={comparisonData.openlane.features}
    alternativeData={alternativeData}
  />
</Section>
<Section class="pt-6!">
  <SectionSubtitle>
    Considering a move away from an {alternativeData.name}? We offer incentives
    to help teams transition smoothly. <br />Contact us at <a
      href="mailto:info@theopenlane.io"
      >info@theopenlane.io
    </a>.
  </SectionSubtitle>
</Section>
<Section />
