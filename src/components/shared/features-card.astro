---
type Info = {
  title: string;
  description: string;
  icon: string;
};

interface Props {
  data: Info;
  class?: string;
  titleClass?: string;
  titleDescriptionContainerClass?: string;
  descriptionClass?: string;
  descriptionContainerClass?: string;
}

const {
  data,
  class: className = "",
  titleClass = "",
  descriptionClass = "",
  descriptionContainerClass = "",
  titleDescriptionContainerClass = "",
} = Astro.props as {
  data?: Info;
  class?: string;
  titleClass?: string;
  descriptionClass?: string;
  descriptionContainerClass?: string;
  titleDescriptionContainerClass?: string;
};
---

{
  data && (
    <div
      class={`flex flex-col justify-between p-6 h-70 rounded-3xl
         bg-[linear-gradient(180deg,rgba(154,245,220,0.08)_0%,#fff_100%)]
         shadow-[0_0_0_1px_rgba(9,21,29,0.08),0_14px_4px_0_rgba(9,21,29,0),0_9px_4px_0_rgba(9,21,29,0.01),0_5px_3px_0_rgba(9,21,29,0.02),0_2px_2px_0_rgba(9,21,29,0.03),0_1px_1px_0_rgba(9,21,29,0.04)]!
         fade-in-scroll gap-2 ${className}`}
    >
      <div class="flex items-center justify-center h-12 w-12 rounded-lg shadow-sm bg-white">
        <img src={data.icon} alt={data.title} class="h-6 w-6" />
      </div>
      <div
        class={`flex flex-col flex-1 mt-2 ${titleDescriptionContainerClass}`}
      >
        <div
          class={`text-title-section text-xl tracking-[-0.6px] ${titleClass}`}
        >
          <span class="font-semibold">{data.title}</span>
        </div>

        <div class={`flex-1 flex items-end ${descriptionContainerClass}`}>
          <div
            class={`font-normal leading-7 text-subtitle text-base ${descriptionClass}`}
          >
            {data.description}
          </div>
        </div>
      </div>
    </div>
  )
}
