---
import { CircleCheckBig, CircleX } from "lucide-react";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactLayout from "../../layouts/contact/Contact.astro";
---

<BaseLayout>
  <ContactLayout />
  <div id="toast-container" class="fixed bottom-4 right-4 z-50 space-y-2"></div>
  <div id="toast-icons" class="hidden">
    <div id="toast-icon-success">
      <CircleCheckBig className="w-5 h-5 text-color-primary" />
    </div>
    <div id="toast-icon-error">
      <CircleX className="w-5 h-5 text-color-fail" />
    </div>
  </div>
</BaseLayout>
